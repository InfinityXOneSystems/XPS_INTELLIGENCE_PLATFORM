  "data_dependencies": [
    {
      "name": "Railway REST API",
      "type": "live-api",
      "url": "https://xps-intelligence.up.railway.app/api/leads",
      "params": "limit=2000",
      "timeout_ms": 8000,
      "fallback": "scored_leads.json"
    },
    {
      "name": "scored_leads.json",
      "type": "static-file",
      "path": "./data/scored_leads.json",
      "description": "Pre-scored lead records (Railway API fallback)"
    },
    {
      "name": "scoring_report.json",
      "type": "static-file",
      "path": "./data/scoring_report.json",
      "description": "Scoring metadata report"
    }

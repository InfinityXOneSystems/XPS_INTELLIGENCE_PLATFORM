# XPS Intelligence Backend — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
#
# Railway automatically injects DATABASE_URL and REDIS_URL from linked
# services.  The application auto-converts postgres:// → postgresql+asyncpg://
# so you do NOT need to modify the URL format Railway provides.

# ── Database (Railway Postgres) ───────────────────────────────────────────────
# Railway provides this automatically when you link a Postgres service.
# Format accepted: postgresql+asyncpg://, postgresql://, or postgres://
# Provisioned instance: postgres-production-5596.up.railway.app:5432
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@postgres-production-5596.up.railway.app:5432/railway

# ── Redis (Railway Redis) ─────────────────────────────────────────────────────
# Railway provides this automatically when you link a Redis service.
# Provisioned proxy: tramway.proxy.rlwy.net:22806
REDIS_URL=redis://tramway.proxy.rlwy.net:22806

# ── Object Storage ────────────────────────────────────────────────────────────
OBJECT_STORAGE_ENDPOINT=https://t3.storageapi.dev
OBJECT_STORAGE_BUCKET=stocked-organizer-khf6nyu
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=

# ── Security ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ── LLM Routing (server-side only — NEVER set NEXT_PUBLIC_ for these) ─────────
LLM_PROVIDER=groq
LLM_SECONDARY_PROVIDER=echo
GROQ_API_KEY=

# ── Feature Flags ─────────────────────────────────────────────────────────────
AUTONOMY_ENABLED=false
SCRAPER_AUTORUN_ENABLED=false
SANDBOX_NETWORK_MODE=restricted

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── CORS (comma-separated JSON array) ────────────────────────────────────────
# Include the Railway frontend service URL when deployed:
#   ["https://your-frontend.up.railway.app","http://localhost:3000"]
CORS_ORIGINS=["http://localhost:3000"]

# XPS Intelligence Frontend — Environment Variables
# Copy to .env.local and fill in real values. NEVER commit .env.local.
#
# NEXT_PUBLIC_* variables are baked into the browser bundle at build time.
# They are safe to expose — do NOT put secrets here.

# ── Backend API URL ────────────────────────────────────────────────────────────
# The full URL of the deployed xps-backend Railway service.
# Used by Next.js rewrites to proxy /api/v1/* to the backend.
# Example: https://xps-backend-production.up.railway.app
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ── Legacy Dashboard ──────────────────────────────────────────────────────────
# The GitHub Pages URL for the legacy XPS dashboard iframe.
# Leave blank to use the default: https://infinityxonesystems.github.io/XPS_INTELLIGENCE_SYSTEM/
NEXT_PUBLIC_LEGACY_DASHBOARD_URL=

# Mode: "iframe" (default, safe) or "native" (when parity is confirmed).
NEXT_PUBLIC_LEGACY_DASHBOARD_MODE=iframe

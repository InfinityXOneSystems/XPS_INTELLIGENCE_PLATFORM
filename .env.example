# XPS Intelligence Platform — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is in .gitignore.

# ── Database (Railway Postgres) ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/xps_db

# ── Cache (Railway Redis) ────────────────────────────────────────────────
REDIS_URL=redis://user:password@host:6379/0

# ── Authentication ────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-32-chars-minimum

# ── Environment ───────────────────────────────────────────────────────────
ENVIRONMENT=development
# Options: development | staging | production

# ── LLM: GitHub Copilot (Primary) ────────────────────────────────────────
COPILOT_TOKEN=your-github-copilot-token

# ── LLM: Groq (Secondary Fallback) ───────────────────────────────────────
GROQ_API_KEY=your-groq-api-key

# ── Supabase (Optional Extended Storage) ─────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Railway ───────────────────────────────────────────────────────────────
RAILWAY_TOKEN=your-railway-api-token

# ── GitGuardian ───────────────────────────────────────────────────────────
GITGUARDIAN_API_KEY=your-gitguardian-api-key

# ── Application URLs ──────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── Infinity Orchestrator ─────────────────────────────────────────────────
# Configured via GitHub App — no additional env needed for read/write/command

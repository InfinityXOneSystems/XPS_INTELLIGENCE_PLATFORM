# XPS Intelligence Platform — All-in-One Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is already in .gitignore.
#
# For Railway deployment: set these in the Railway service's "Variables" tab.
# DATABASE_URL and REDIS_URL are injected automatically when you link
# the Postgres and Redis services in the Railway dashboard.

# ── Database (Railway Postgres — auto-injected when linked) ──────────────────
# Any of these formats is accepted; the app converts automatically:
#   postgres://, postgresql://, or postgresql+asyncpg://
DATABASE_URL=******postgres-production-5596.up.railway.app:5432/railway

# ── Redis (Railway Redis — auto-injected when linked) ────────────────────────
REDIS_URL=redis://tramway.proxy.rlwy.net:22806

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED: generate with `openssl rand -hex 32`
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ── LLM Routing (server-side only — NEVER expose to browser) ─────────────────
GROQ_API_KEY=
LLM_PROVIDER=groq

# ── Feature Flags ─────────────────────────────────────────────────────────────
AUTONOMY_ENABLED=false
SCRAPER_AUTORUN_ENABLED=false

# ── Object Storage ────────────────────────────────────────────────────────────
OBJECT_STORAGE_ENDPOINT=https://t3.storageapi.dev
OBJECT_STORAGE_BUCKET=stocked-organizer-khf6nyu
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=

# ── Frontend — Legacy Dashboard ───────────────────────────────────────────────
# The GitHub Pages URL embedded in the iframe on /legacy-dashboard.
# Leave blank to use the default.
NEXT_PUBLIC_LEGACY_DASHBOARD_URL=
NEXT_PUBLIC_LEGACY_DASHBOARD_MODE=iframe

# ── CORS ──────────────────────────────────────────────────────────────────────
# In all-in-one mode the frontend and backend share one origin, so only
# localhost is needed here. Add your Railway app URL after first deploy.
CORS_ORIGINS=["http://localhost:3000"]

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Legacy / CI variables ─────────────────────────────────────────────────────
RAILWAY_TOKEN=your-railway-api-token
GITGUARDIAN_API_KEY=your-gitguardian-api-key

# ── NOTE ─────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_BACKEND_URL is NOT needed in all-in-one mode because the
# Next.js server (node server.js) and the FastAPI backend (uvicorn) both
# run inside the same container. The Next.js rewrite proxy uses
# BACKEND_INTERNAL_URL=http://127.0.0.1:8000 set automatically by
# supervisord.conf. No extra env var needed from the Railway UI.
